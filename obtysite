    <script>
    // ========== ASCII TEXT COMPONENT (THREE.js) ==========
    Math.map = function(n, start, stop, start2, stop2) {
        return ((n - start) / (stop - start)) * (stop2 - start2) + start2;
    };

    const PX_RATIO = window.devicePixelRatio || 1;

    class AsciiFilter {
        constructor(renderer, opts = {}) {
            this.renderer = renderer;
            this.domElement = document.createElement('div');
            this.domElement.style.position = 'absolute';
            this.domElement.style.top = '0';
            this.domElement.style.left = '0';
            this.domElement.style.width = '100%';
            this.domElement.style.height = '100%';
            this.pre = document.createElement('pre');
            this.domElement.appendChild(this.pre);
            this.canvas = document.createElement('canvas');
            this.context = this.canvas.getContext('2d');
            this.domElement.appendChild(this.canvas);
            this.deg = 0;
            this.invert = opts.invert ?? true;
            this.fontSize = opts.fontSize ?? 12;
            this.fontFamily = opts.fontFamily ?? "'Courier New', monospace";
            this.charset = opts.charset ?? " .'`^\",:;Il!i~+_-?][}{1)(|/tfjrxnuvczXYUJCLQ0OZmwqpdbkhao*#MW&8%B@$";
            this.context.imageSmoothingEnabled = false;
            this.onMouseMove = this.onMouseMove.bind(this);
            document.addEventListener('mousemove', this.onMouseMove);
        }
        setSize(w, h) {
            this.width = w; this.height = h;
            this.renderer.setSize(w, h);
            this.reset();
            this.center = {x: w/2, y: h/2};
            this.mouse = {x: this.center.x, y: this.center.y};
        }
        reset() {
            this.context.font = this.fontSize + 'px ' + this.fontFamily;
            var cw = this.context.measureText('A').width;
            this.cols = Math.floor(this.width / (this.fontSize * (cw / this.fontSize)));
            this.rows = Math.floor(this.height / this.fontSize);
            this.canvas.width = this.cols;
            this.canvas.height = this.rows;
            this.pre.style.fontFamily = this.fontFamily;
            this.pre.style.fontSize = this.fontSize + 'px';
            this.pre.style.margin = '0';
            this.pre.style.padding = '0';
            this.pre.style.lineHeight = '1em';
            this.pre.style.position = 'absolute';
            this.pre.style.left = '0';
            this.pre.style.top = '0';
            this.pre.style.zIndex = '9';
            this.pre.style.backgroundAttachment = 'fixed';
            this.pre.style.mixBlendMode = 'difference';
        }
        render(scene, camera) {
            this.renderer.render(scene, camera);
            var w = this.canvas.width, h = this.canvas.height;
            this.context.clearRect(0, 0, w, h);
            if (this.context && w && h) this.context.drawImage(this.renderer.domElement, 0, 0, w, h);
            this.asciify(this.context, w, h);
            this.hue();
        }
        onMouseMove(e) { this.mouse = {x: e.clientX * PX_RATIO, y: e.clientY * PX_RATIO}; }
        get dx() { return this.mouse.x - this.center.x; }
        get dy() { return this.mouse.y - this.center.y; }
        hue() {
            var deg = (Math.atan2(this.dy, this.dx) * 180) / Math.PI;
            this.deg += (deg - this.deg) * 0.075;
            this.domElement.style.filter = 'hue-rotate(' + this.deg.toFixed(1) + 'deg)';
        }
        asciify(ctx, w, h) {
            if (!w || !h) return;
            var imgData = ctx.getImageData(0, 0, w, h).data;
            var str = '';
            for (var y = 0; y < h; y++) {
                for (var x = 0; x < w; x++) {
                    var i = x * 4 + y * 4 * w;
                    var r = imgData[i], g = imgData[i+1], b = imgData[i+2], a = imgData[i+3];
                    if (a === 0) { str += ' '; continue; }
                    var gray = (0.3*r + 0.6*g + 0.1*b) / 255;
                    var idx = Math.floor((1-gray) * (this.charset.length - 1));
                    if (this.invert) idx = this.charset.length - idx - 1;
                    str += this.charset[idx];
                }
                str += '\n';
            }
            this.pre.textContent = str;
        }
        dispose() { document.removeEventListener('mousemove', this.onMouseMove); }
    }

    class CanvasTxt {
        constructor(txt, opts = {}) {
            this.canvas = document.createElement('canvas');
            this.context = this.canvas.getContext('2d');
            this.txt = txt;
            this.fontSize = opts.fontSize || 200;
            this.fontFamily = opts.fontFamily || 'Arial';
            this.color = opts.color || '#fdf9f3';
            this.font = '600 ' + this.fontSize + 'px ' + this.fontFamily;
        }
        resize() {
            this.context.font = this.font;
            var m = this.context.measureText(this.txt);
            this.canvas.width = Math.ceil(m.width) + 20;
            this.canvas.height = Math.ceil(m.actualBoundingBoxAscent + m.actualBoundingBoxDescent) + 20;
        }
        render() {
            this.context.clearRect(0, 0, this.canvas.width, this.canvas.height);
            this.context.fillStyle = this.color;
            this.context.font = this.font;
            var m = this.context.measureText(this.txt);
            this.context.fillText(this.txt, 10, 10 + m.actualBoundingBoxAscent);
        }
        get width() { return this.canvas.width; }
        get height() { return this.canvas.height; }
        get texture() { return this.canvas; }
    }

    (function initASCIIText() {
        var container = document.getElementById('asciiTextContainer');
        if (!container) return;

        var vertexShader = [
            'varying vec2 vUv;',
            'uniform float uTime;',
            'uniform float uEnableWaves;',
            'void main() {',
            '    vUv = uv;',
            '    float time = uTime * 5.0;',
            '    float wf = uEnableWaves;',
            '    vec3 t = position;',
            '    t.x += sin(time + position.y) * 0.5 * wf;',
            '    t.y += cos(time + position.z) * 0.15 * wf;',
            '    t.z += sin(time + position.x) * wf;',
            '    gl_Position = projectionMatrix * modelViewMatrix * vec4(t, 1.0);',
            '}'
        ].join('\n');

        var fragmentShader = [
            'varying vec2 vUv;',
            'uniform float uTime;',
            'uniform sampler2D uTexture;',
            'void main() {',
            '    float time = uTime;',
            '    vec2 pos = vUv;',
            '    float r = texture2D(uTexture, pos + cos(time*2.0 - time + pos.x)*.01).r;',
            '    float g = texture2D(uTexture, pos + tan(time*.5 + pos.x - time)*.01).g;',
            '    float b = texture2D(uTexture, pos - cos(time*2.0 + time + pos.y)*.01).b;',
            '    float a = texture2D(uTexture, pos).a;',
            '    gl_FragColor = vec4(r, g, b, a);',
            '}'
        ].join('\n');

        function setup() {
            var rect = container.getBoundingClientRect();
            var w = rect.width, h = rect.height;
            if (w === 0 || h === 0) { setTimeout(setup, 100); return; }

            var textCanvas = new CanvasTxt('obty.ai', {fontSize: 200, fontFamily: 'IBM Plex Mono', color: '#fdf9f3'});
            textCanvas.resize();
            textCanvas.render();

            var texture = new THREE.CanvasTexture(textCanvas.texture);
            texture.minFilter = THREE.NearestFilter;

            var aspect = textCanvas.width / textCanvas.height;
            var baseH = 8;
            var geo = new THREE.PlaneGeometry(baseH * aspect, baseH, 36, 36);
            var mat = new THREE.ShaderMaterial({
                vertexShader: vertexShader,
                fragmentShader: fragmentShader,
                transparent: true,
                uniforms: {
                    uTime: {value: 0},
                    uTexture: {value: texture},
                    uEnableWaves: {value: 1.0}
                }
            });

            var camera = new THREE.PerspectiveCamera(45, w/h, 1, 1000);
            camera.position.z = 30;
            var scene = new THREE.Scene();
            var mesh = new THREE.Mesh(geo, mat);
            scene.add(mesh);

            var renderer = new THREE.WebGLRenderer({antialias: false, alpha: true});
            renderer.setPixelRatio(1);
            renderer.setClearColor(0x000000, 0);

            var filter = new AsciiFilter(renderer, {fontFamily: 'IBM Plex Mono', fontSize: 8, invert: true});
            container.appendChild(filter.domElement);
            filter.setSize(w, h);

            var mouseLocal = {x: w/2, y: h/2};
            container.addEventListener('mousemove', function(evt) {
                var b = container.getBoundingClientRect();
                mouseLocal.x = evt.clientX - b.left;
                mouseLocal.y = evt.clientY - b.top;
            });

            function animate() {
                requestAnimationFrame(animate);
                var t = new Date().getTime() * 0.001;
                textCanvas.render();
                texture.needsUpdate = true;
                mat.uniforms.uTime.value = Math.sin(t);
                var rx = Math.map(mouseLocal.y, 0, h, 0.5, -0.5);
                var ry = Math.map(mouseLocal.x, 0, w, -0.5, 0.5);
                mesh.rotation.x += (rx - mesh.rotation.x) * 0.05;
                mesh.rotation.y += (ry - mesh.rotation.y) * 0.05;
                filter.render(scene, camera);
            }
            animate();

            var ro = new ResizeObserver(function(entries) {
                if (!entries[0]) return;
                var cr = entries[0].contentRect;
                if (cr.width > 0 && cr.height > 0) {
                    camera.aspect = cr.width / cr.height;
                    camera.updateProjectionMatrix();
                    filter.setSize(cr.width, cr.height);
                }
            });
            ro.observe(container);
        }

        document.fonts.ready.then(setup);
    })();

    // ========== BUBBLE MENU COMPONENT (GSAP) ==========
    (function initBubbleMenu() {
        var btn = document.getElementById('bubbleMenuBtn');
        var overlay = document.getElementById('bubbleMenuOverlay');
        var pillList = overlay.querySelector('.pill-list');
        var isOpen = false;

        var items = [
            {label: '\u0413\u043b\u0430\u0432\u043d\u0430\u044f', href: '#', rotation: -8, hoverBg: '#3b82f6', hoverColor: '#fff'},
            {label: '\u0412\u043e\u0437\u043c\u043e\u0436\u043d\u043e\u0441\u0442\u0438', href: '#features', rotation: 8, hoverBg: '#10b981', hoverColor: '#fff'},
            {label: '\u0413\u0430\u043b\u0435\u0440\u0435\u044f', href: '#gallery', rotation: 8, hoverBg: '#f59e0b', hoverColor: '#fff'},
            {label: '\u0422\u0430\u0440\u0438\u0444\u044b', href: '#pricing', rotation: -8, hoverBg: '#ef4444', hoverColor: '#fff'},
            {label: '\u041a\u043e\u043d\u0442\u0430\u043a\u0442\u044b', href: '#', rotation: 8, hoverBg: '#8b5cf6', hoverColor: '#fff'}
        ];

        items.forEach(function(item) {
            var li = document.createElement('li');
            li.className = 'pill-col';
            li.setAttribute('role', 'none');
            var a = document.createElement('a');
            a.className = 'pill-link';
            a.setAttribute('role', 'menuitem');
            a.href = item.href;
            a.style.setProperty('--item-rot', item.rotation + 'deg');
            a.style.setProperty('--hover-bg', item.hoverBg);
            a.style.setProperty('--hover-color', item.hoverColor);
            var span = document.createElement('span');
            span.className = 'pill-label';
            span.textContent = item.label;
            a.appendChild(span);
            li.appendChild(a);
            pillList.appendChild(li);

            a.addEventListener('click', function() {
                if (isOpen) toggleMenu();
            });
        });

        function toggleMenu() {
            isOpen = !isOpen;
            btn.classList.toggle('open', isOpen);
            btn.setAttribute('aria-pressed', isOpen);
            overlay.setAttribute('aria-hidden', !isOpen);

            var bubbles = pillList.querySelectorAll('.pill-link');
            var labels = pillList.querySelectorAll('.pill-label');

            if (isOpen) {
                overlay.style.display = 'flex';
                gsap.killTweensOf(bubbles);
                gsap.killTweensOf(labels);
                gsap.set(bubbles, {scale: 0, transformOrigin: '50% 50%'});
                gsap.set(labels, {y: 24, autoAlpha: 0});

                bubbles.forEach(function(bubble, i) {
                    var delay = i * 0.12 + gsap.utils.random(-0.05, 0.05);
                    var tl = gsap.timeline({delay: delay});
                    tl.to(bubble, {scale: 1, duration: 0.5, ease: 'back.out(1.5)'});
                    if (labels[i]) {
                        tl.to(labels[i], {y: 0, autoAlpha: 1, duration: 0.5, ease: 'power3.out'}, '-=0.45');
                    }
                });
            } else {
                gsap.killTweensOf(bubbles);
                gsap.killTweensOf(labels);
                gsap.to(labels, {y: 24, autoAlpha: 0, duration: 0.2, ease: 'power3.in'});
                gsap.to(bubbles, {scale: 0, duration: 0.2, ease: 'power3.in', onComplete: function() {
                    overlay.style.display = 'none';
                }});
            }
        }

        btn.addEventListener('click', toggleMenu);
    })();

    // ========== DOCK MAGNIFICATION (vanilla JS) ==========
    (function initDock() {
        var panel = document.getElementById('dockPanel');
        if (!panel) return;
        var items = panel.querySelectorAll('.dock-item');
        var baseSize = 50, maxSize = 70, distance = 200;

        panel.addEventListener('mousemove', function(e) {
            items.forEach(function(item) {
                var rect = item.getBoundingClientRect();
                var cx = rect.left + rect.width / 2;
                var d = Math.abs(e.pageX - cx);
                var scale = Math.max(baseSize, maxSize - (d / distance) * (maxSize - baseSize));
                if (d > distance) scale = baseSize;
                item.style.width = scale + 'px';
                item.style.height = scale + 'px';
            });
        });

        panel.addEventListener('mouseleave', function() {
            items.forEach(function(item) {
                item.style.width = baseSize + 'px';
                item.style.height = baseSize + 'px';
            });
        });
    })();

    // ========== FOLDER BACK COLOR ==========
    document.querySelectorAll('.folder__back').forEach(function(back) {
        var color = back.style.background;
        if (back.querySelector('::after')) return;
        // The ::after pseudo-element inherits color via CSS, set it here
        back.style.setProperty('--folder-back-color', color);
    });
    // Set folder back ::after color via dynamic style
    (function() {
        var style = document.createElement('style');
        style.textContent = '#folder1 .folder__back::after { background: #4b3fcc; } #folder2 .folder__back::after { background: #cc8833; } #folder3 .folder__back::after { background: #0e8a5e; }';
        document.head.appendChild(style);
    })();
    </script>
